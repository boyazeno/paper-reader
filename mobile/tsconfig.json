{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vite/client"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["../src/renderer/src/*"],
      "@shared/*": ["../src/shared/*"],
      "@mobile/*": ["src/*"]
    }
  },
  "comment": "Only mobile/src is included directly; reused renderer/shared files are pulled in (and typechecked) transitively through imports, so desktop-only components we don't use are not checked.",
  "include": ["src/**/*"]
}
